{
  "name": "compound-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development next dev --turbopack -p 8080 -H 0.0.0.0",
    "build": "next build",
    "build:measure": "node scripts/measure-build.mjs",
    "start": "next start -p ${PORT:-3000} -H 0.0.0.0",
    "profile:build": "mkdir -p tmp/profiles/build && NODE_OPTIONS=\"--cpu-prof --cpu-prof-dir=tmp/profiles/build\" npm run build:measure",
    "profile:server": "mkdir -p tmp/profiles/home && HOME=$PWD/tmp/profiles/home NO_INSIGHT=1 NO_UPDATE_NOTIFIER=1 clinic flame --open=false --dest tmp/profiles/server -- next start -p ${PORT:-3000} -H 0.0.0.0",
    "profile:heap:build": "mkdir -p tmp/profiles/heap && NODE_OPTIONS=\"--heap-prof --heap-prof-dir=tmp/profiles/heap\" npm run build:measure",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mdx,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,mdx,yml,yaml}\"",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --pretty false",
    "test": "node scripts/run-node-tests.mjs",
    "test:coverage": "node scripts/run-node-tests.mjs --coverage",
    "quality:metrics": "node scripts/quality-metrics.mjs",
    "quality:duplicates": "node scripts/duplicate-detection.mjs",
    "debt:scan": "node scripts/tech-debt-scan.mjs",
    "debt:check": "node scripts/tech-debt-scan.mjs --check",
    "alerts:generate": "node scripts/generate-alert-rules.mjs",
    "alerts:check": "node scripts/generate-alert-rules.mjs --check",
    "validate:agents-md": "node scripts/validate-agents-md.mjs",
    "validate:profiling": "node scripts/validate-profiling-config.mjs",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "docs:api:check": "node scripts/generate-api-docs.mjs --check",
    "check": "npm run format:check && npm run typecheck && npm run test:coverage && npm run quality:metrics && npm run quality:duplicates && npm run debt:check && npm run alerts:check && npm run validate:agents-md && npm run validate:profiling && npm run docs:api:check && npm run build",
    "danger": "danger ci",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,css,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/nextjs": "^8.55.1",
    "better-sqlite3": "^12.9.0",
    "dexie": "4.0.10",
    "dexie-react-hooks": "1.1.7",
    "dompurify": "^3.4.0",
    "lucide-react": "^1.8.0",
    "marked": "15.0.4",
    "nanoid": "5.0.9",
    "next": "^15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "clinic": "^13.0.0",
    "danger": "^12.3.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "3.4.15",
    "typescript": "5.6.3"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22 <23"
  }
}
