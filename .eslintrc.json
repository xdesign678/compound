{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["@typescript-eslint"],
  "ignorePatterns": [
    ".next/",
    "node_modules/",
    "out/",
    "build/",
    "public/workbox-*.js",
    "public/swe-worker-development.js",
    "tmp/",
    "output/"
  ],
  "rules": {
    "import/no-restricted-paths": [
      "error",
      {
        "zones": [
          {
            "target": [
              "./components/**",
              "./app/page.tsx",
              "./app/layout.tsx",
              "./app/global-error.tsx",
              "./app/review/**",
              "./app/sync/**"
            ],
            "from": [
              "./lib/server-db.*",
              "./lib/server-auth.*",
              "./lib/server-ingest.*",
              "./lib/server-logger.*",
              "./lib/gateway.*",
              "./lib/embedding.*",
              "./lib/repair-worker.*",
              "./lib/rate-limit.*",
              "./lib/request-guards.*",
              "./lib/request-context.*",
              "./lib/review-queue.*",
              "./lib/analysis-worker.*",
              "./lib/model-runs.*",
              "./lib/wiki-db.*",
              "./lib/wiki-chunk.*",
              "./lib/wiki-compiler.*",
              "./lib/sync-observability.*",
              "./lib/github-sync-runner.*",
              "./lib/github-sync.*",
              "./lib/observability/**",
              "./lib/logging.*",
              "./lib/circuit-breaker.*"
            ],
            "message": "Server-only modules (Node.js APIs: better-sqlite3, node:fs, node:crypto, process.env, etc.) must not be imported from client-side code. Use app/api/ routes as the interface layer."
          },
          {
            "target": ["./app/api/**"],
            "from": ["./lib/db.ts", "./lib/store.ts"],
            "message": "Client-side DB (Dexie/IDB) and Zustand store must not be imported from server API routes. Use lib/server-db.ts (better-sqlite3) for server-side data access."
          }
        ]
      }
    ],
    "@typescript-eslint/naming-convention": [
      "error",
      {
        "selector": "variable",
        "modifiers": ["const"],
        "format": ["camelCase", "UPPER_CASE", "PascalCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "variable",
        "format": ["camelCase", "UPPER_CASE", "PascalCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "function",
        "format": ["camelCase", "PascalCase", "UPPER_CASE"]
      },
      {
        "selector": "parameter",
        "format": ["camelCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "memberLike",
        "modifiers": ["private"],
        "format": ["camelCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "typeLike",
        "format": ["PascalCase"]
      },
      {
        "selector": "enumMember",
        "format": ["PascalCase", "UPPER_CASE"]
      },
      {
        "selector": "property",
        "modifiers": ["static", "readonly"],
        "format": ["UPPER_CASE", "camelCase"]
      }
    ]
  }
}
