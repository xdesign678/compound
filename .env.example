# ==============================================================
# Compound 访问保护
# --------------------------------------------------------------
# 生产环境必须配置一个强随机密钥；否则 middleware 会阻止公开访问。
# 浏览器会弹出 Basic Auth，也可以在 Settings → 访问保护里保存同一个 token。
# ==============================================================
COMPOUND_ADMIN_TOKEN=change-me-to-a-long-random-secret
# 兼容旧命名，也可用 ADMIN_TOKEN。
# ADMIN_TOKEN=change-me-to-a-long-random-secret

# ==============================================================
# LLM 网关（服务端转发 OpenAI-compatible chat completions 接口）
# --------------------------------------------------------------
# 注意：这里必须是 chat completions endpoint，不是 base URL。
# 自定义用户 API URL 必须同时提供用户自己的 API Key；服务端 Key 不会发往用户自定义 URL。
# ==============================================================
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# 如需禁用前端 Settings 中的自定义 API URL：
# COMPOUND_ALLOW_CUSTOM_LLM_API_URL=false
# 每分钟 LLM 请求上限，0 表示关闭内存限流。
COMPOUND_LLM_RATE_LIMIT_PER_MINUTE=20

# --------------------------------------------------------------
# 超时与降级（仅在你确实知道自己在做什么时才覆盖默认值！）
# --------------------------------------------------------------
# 单次 LLM 调用的总时长上限（毫秒）。OpenRouter 免费档 + reasoning
# 模型常见 60–120s，默认 180s 是安全值。**请勿设成 ≤60s**，否则
# 大批量同步会全部撞超时。
# COMPOUND_LLM_TIMEOUT_MS=180000
# Reasoning 模型（o1/r1/m2/mimo/deepseek-v3+ 等）额外延长时长，叠加在
# COMPOUND_LLM_TIMEOUT_MS 之上。默认 60s。
# COMPOUND_LLM_REASONING_EXTRA_MS=60000
# Streaming 模式下，未收到任何 chunk 的最长间隔。默认 45s，每次收到
# token 自动重置，因此只要模型在持续吐字就不会被打断。
# COMPOUND_LLM_STREAM_IDLE_MS=45000
# 是否对 reasoning 模型默认开 streaming（true/false）。默认 true。
# COMPOUND_LLM_STREAM_REASONING=true
# 同一模型连续 N 次 timeout 后，下一次自动切到 fallback 列表的下一个模型。
# 设 0 可关闭自动降级。
# COMPOUND_LLM_AUTO_FALLBACK_AFTER=3
# 多模型轮询列表（逗号分隔）。每个模型独立计 timeout 计数，超阈值的会被
# 跳过，永远把请求送到当前还没坏的那个。例：
# COMPOUND_LLM_FALLBACK_MODELS=mimo-v2.5-pro,deepseek-v4-flash,deepseek-v4-pro,mimo-v2.5
# 兜底单模型（列表全部撞墙时使用）。
# COMPOUND_LLM_FALLBACK_MODEL=openai/gpt-4o-mini
# Embedding 与 GitHub fetch 的独立超时（毫秒）。
# COMPOUND_EMBEDDING_TIMEOUT_MS=60000
# COMPOUND_GITHUB_FETCH_TIMEOUT_MS=30000

# ==============================================================
# GitHub 同步（从 Obsidian 笔记仓库拉取 Markdown）
# --------------------------------------------------------------
# GITHUB_REPO : "owner/repo" 形式，或完整的 github.com URL
# GITHUB_TOKEN : fine-grained PAT，Repository → Contents: Read-only
# 生成入口: https://github.com/settings/tokens?type=beta
# GITHUB_BRANCH : 分支名，默认 main
# ==============================================================
GITHUB_REPO=xdesign678/myobs
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx
GITHUB_BRANCH=main
COMPOUND_SYNC_RATE_LIMIT_PER_MINUTE=10

# ==============================================================
# 数据持久化（服务端 SQLite）
# --------------------------------------------------------------
# DATA_DIR 指向一个挂载的持久卷目录，compound.db 会写在这里。
# 本地开发不填，会自动落到 ./data/compound.db（已在 .gitignore）。
#
# Zeabur 部署步骤：
# 1. 控制台 → 服务 → Volumes → Add Volume
#    Mount Path: /data
#    Size: 1 GB 足够（<100k 条笔记）
# 2. Variables → 添加 DATA_DIR=/data
# 3. 重新部署
# ==============================================================
DATA_DIR=/data

# ==============================================================
# Wiki 编译层（分块检索 / 证据链）
# --------------------------------------------------------------
# 长文档会按标题和 token 估算切块，问答会把客户端候选概念与服务端
# 概念检索、证据链、原文分块一起拼成上下文。
# ==============================================================
COMPOUND_CHUNK_MAX_TOKENS=1200
COMPOUND_CHUNK_OVERLAP_TOKENS=120
COMPOUND_QUERY_CONTEXT_CONCEPT_LIMIT=24
COMPOUND_QUERY_CONTEXT_CHUNK_LIMIT=12

# ==============================================================
# Sentry — error tracking with source maps + breadcrumbs
# --------------------------------------------------------------
# Provide a DSN to enable production error tracking. Without a DSN
# the Sentry SDK is a no-op (safe for local dev / PR previews).
#
# - SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN: project DSN (server / client)
# - SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN: required only at
#   build time when you want the Next.js plugin to upload source maps
#   so production stack traces map back to TypeScript source.
# - SENTRY_ENVIRONMENT: usually "production" / "staging" / "development"
# - SENTRY_RELEASE: opaque release identifier (e.g. git sha) — when set
#   the same value should be passed to both server and client builds.
# - SENTRY_TRACES_SAMPLE_RATE: 0.0 - 1.0, fraction of transactions
#   to send to Sentry (default 0.1 = 10%).
# ==============================================================
# SENTRY_DSN=YOUR_SENTRY_DSN_HERE
# NEXT_PUBLIC_SENTRY_DSN=YOUR_PUBLIC_SENTRY_DSN_HERE
# SENTRY_ORG=YOUR_ORG_SLUG
# SENTRY_PROJECT=compound
# SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN_HERE
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
