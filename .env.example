# ==============================================================
# LLM 网关（服务端转发 OpenAI-兼容接口）
# --------------------------------------------------------------
# 服务端 GitHub 同步必须配置这三个变量（前端 Settings 里填的 Key
# 只用于浏览器手动摄入，不会被服务端同步使用）。
# ==============================================================
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ==============================================================
# GitHub 同步（从 Obsidian 笔记仓库拉取 Markdown）
# --------------------------------------------------------------
# GITHUB_REPO    :  "owner/repo" 形式，或完整的 github.com URL
# GITHUB_TOKEN   :  fine-grained PAT，Repository → Contents: Read-only
#                   生成入口: https://github.com/settings/tokens?type=beta
# GITHUB_BRANCH  :  分支名，默认 main
# ==============================================================
GITHUB_REPO=xdesign678/myobs
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx
GITHUB_BRANCH=main

# ==============================================================
# 数据持久化（服务端 SQLite）
# --------------------------------------------------------------
# DATA_DIR 指向一个挂载的持久卷目录，compound.db 会写在这里。
# 本地开发不填，会自动落到 ./data/compound.db（已在 .gitignore）。
#
# Zeabur 部署步骤：
#   1. 控制台 → 服务 → Volumes → Add Volume
#      Mount Path:  /data
#      Size:        1 GB 足够（<100k 条笔记）
#   2. Variables → 添加 DATA_DIR=/data
#   3. 重新部署
# ==============================================================
DATA_DIR=/data
